# ─── TWILIO ────────────────────────────────────────────────
# Your Twilio Account SID, Auth Token, and purchased Phone Number
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── OPENAI (STT - Whisper) ────────────────────────────────
# Used for transcribing user speech via OpenAI Whisper API
OPENAI_API_KEY=your_openai_api_key

# ─── GROQ (LLM - Llama 3) ──────────────────────────────────
# Used for the fast conversational engine (Llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_api_key

# ─── ELEVENLABS (Optional - Voice Cloning) ─────────────────
# Used for cloning custom voice, if configured (fallback to EdgeTTS is default)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_cloned_voice_id

# ─── SUPABASE ──────────────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── APP CONFIGURATION ──────────────────────────────────────
PORT=3000
# The public HTTPS URL of your server (e.g., ngrok URL during development, or Render/Railway URL in production)
BASE_URL=https://your-subdomain.ngrok-free.dev
NODE_ENV=development
